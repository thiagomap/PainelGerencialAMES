# ── Datas importantes ────────────────────────────────────────────
# Atualizar mensalmente com novos XLS do sistema Gestão em Saúde (SES/SP)
# Processo: substituir XLS nas 3 pastas → executar: node gerar-dados.js
# O dashboard, indicadores.html e ame-detalhe.html atualizam automaticamente
ULTIMA_ATUALIZACAO=2026-05-15
PERIODO_ATUAL=Jan-Abr/2026
MESES_REALIZADOS=4
MESES_SEMESTRE=6

# ── API CLAUDE (Anthropic) ────────────────────────────────────
# Necessário para análise de Planos de Ação dos AMEs
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Se vazio → usa Ollama local automaticamente (gratuito)

# ── Ollama (IA local, gratuita) ───────────────────────────────
# Deve estar rodando em: http://localhost:11434
# Iniciar: ollama serve  |  Listar modelos: ollama list
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434


# ================================================================
# SEÇÃO 6 — CONFIGURAÇÕES DO SISTEMA (servidor + deploy)
# ================================================================

# ── Servidor local ──────────────────────────────────────────────
PORTA_LOCAL=3000
# Acesso local:    http://localhost:3000
# Acesso na rede:  http://172.16.182.3:3000

# ── Deploy Vercel (online) ──────────────────────────────────────
VERCEL_URL=https://relatorio-gerencial-santa-casa.vercel.app
# Para redesenhar e republicar: cd deploy && npx vercel --prod --yes

# ── Atualização dos dados ────────────────────────────────────────
# 1. Dados financeiros e de produção (mensalmente):
#    a) Copiar novos XLS para as pastas de Fluxo de Caixa
#    b) Executar: node gerar-dados.js
# 2. Metas Trimestrais (quando chegarem novos documentos):
#    a) Copiar planilhas para Metas Trimestrais/
#    b) Executar: node gerar-dados-trim.js
# 3. Publicar no Vercel:
#    a) Executar: node publicar.js  (copia arquivos e faz deploy)

# ── Metas Trimestrais — configuração por trimestre ──────────────
